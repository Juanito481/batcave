{
  "name": "batcave",
  "displayName": "Bat Cave",
  "description": "Pixel art visualization of Claude Code activity with animated chess-piece agents in a DC-style lab environment",
  "version": "3.0.0",
  "publisher": "juanito481",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Juanito481/batcave"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "batcave",
          "title": "Bat Cave",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "batcave": [
        {
          "type": "webview",
          "id": "batcave.mainView",
          "name": "Bat Cave"
        }
      ]
    },
    "commands": [
      {
        "command": "batcave.show",
        "title": "Bat Cave: Show"
      },
      {
        "command": "batcave.reset",
        "title": "Bat Cave: Reset View"
      },
      {
        "command": "batcave.toggleSound",
        "title": "Bat Cave: Toggle Sound"
      },
      {
        "command": "batcave.exportSessions",
        "title": "Bat Cave: Export Session History"
      }
    ],
    "configuration": {
      "title": "Bat Cave",
      "properties": {
        "batcave.soundEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable procedural sound effects in the Bat Cave"
        },
        "batcave.soundVolume": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 100,
          "description": "Sound volume (0-100)"
        },
        "batcave.costBudget": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Session cost budget in USD (0 = no limit). Shows alert when exceeded."
        },
        "batcave.role": {
          "type": "string",
          "enum": [
            "master",
            "member"
          ],
          "default": "member",
          "description": "Team role: master can assign agents and manage schedules."
        },
        "batcave.teamServer": {
          "type": "string",
          "default": "",
          "description": "BatCave Command Server URL (e.g. ws://localhost:7777). Leave empty for solo mode."
        },
        "batcave.memberName": {
          "type": "string",
          "default": "",
          "description": "Your display name in the team cave. Defaults to OS username."
        }
      }
    }
  },
  "scripts": {
    "server": "npx tsx server/index.ts",
    "vscode:prepublish": "npm run build",
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "build:webview": "cd webview && npx vite build",
    "watch:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "watch:webview": "cd webview && npx vite build --watch",
    "dev": "concurrently \"npm run watch:ext\" \"npm run watch:webview\"",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.100.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
