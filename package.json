{
  "name": "batcave",
  "displayName": "Bat Cave",
  "description": "Pixel art visualization of Claude Code activity with animated chess-piece agents in a DC-style lab environment",
  "version": "5.5.0",
  "publisher": "juanito481",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Juanito481/batcave"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "batcave",
          "title": "Bat Cave",
          "icon": "assets/icon.svg"
        }
      ]
    },
    "views": {
      "batcave": [
        {
          "type": "webview",
          "id": "batcave.mainView",
          "name": "Bat Cave"
        }
      ],
      "explorer": [
        {
          "id": "batcave.chainsView",
          "name": "Scacchiera Chains",
          "icon": "$(link)",
          "contextualTitle": "Scacchiera Chains"
        },
        {
          "id": "batcave.oracleView",
          "name": "Oracle",
          "icon": "$(symbol-misc)",
          "contextualTitle": "Oracle Knowledge Graph"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "batcave.chainsView",
        "contents": "No active Scacchiera chains.\n\nStart one with `/marshal build: <goal>` in Claude Code, or [open the Bat Cave](command:batcave.show) to see agents.\n\n[Refresh](command:batcave.refreshChains)"
      },
      {
        "view": "batcave.oracleView",
        "contents": "Oracle knowledge graph not built yet.\n\nRun `/oracle build` in Claude Code, or wait for the post-commit hook.\n\n[Refresh](command:batcave.refreshOracle)"
      }
    ],
    "commands": [
      {
        "command": "batcave.show",
        "title": "Bat Cave: Show"
      },
      {
        "command": "batcave.reset",
        "title": "Bat Cave: Reset View"
      },
      {
        "command": "batcave.toggleSound",
        "title": "Bat Cave: Toggle Sound"
      },
      {
        "command": "batcave.exportSessions",
        "title": "Bat Cave: Export Session History"
      },
      {
        "command": "batcave.replaySession",
        "title": "Bat Cave: Replay Session"
      },
      {
        "command": "batcave.enterKonami",
        "title": "Bat Cave: Enter Konami Code"
      },
      {
        "command": "batcave.openChainStatus",
        "title": "Bat Cave: Open Chain Status"
      },
      {
        "command": "batcave.refreshChains",
        "title": "Bat Cave: Refresh Chains",
        "icon": "$(refresh)"
      },
      {
        "command": "batcave.openOracleReport",
        "title": "Bat Cave: Open Oracle Report"
      },
      {
        "command": "batcave.refreshOracle",
        "title": "Bat Cave: Refresh Oracle",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "batcave.refreshChains",
          "when": "view == batcave.chainsView",
          "group": "navigation"
        },
        {
          "command": "batcave.refreshOracle",
          "when": "view == batcave.oracleView",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "Bat Cave",
      "properties": {
        "batcave.soundEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable procedural sound effects in the Bat Cave"
        },
        "batcave.soundVolume": {
          "type": "number",
          "default": 15,
          "minimum": 0,
          "maximum": 100,
          "description": "Sound volume (0-100)"
        },
        "batcave.telemetrySource": {
          "type": "string",
          "enum": [
            "auto",
            "jsonl",
            "otel",
            "both"
          ],
          "default": "auto",
          "description": "Where to read Claude Code activity from. 'auto' uses OTel if available, falls back to JSONL. See docs/monitoring-setup.md."
        },
        "batcave.otelEventsFile": {
          "type": "string",
          "default": "~/.batcave/otel-events.jsonl",
          "description": "Path to the OTel events file written by the local OTel Collector (file/json exporter). Supports ~ expansion."
        }
      }
    }
  },
  "scripts": {
    "server": "npx tsx server/index.ts",
    "vscode:prepublish": "npm run build",
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --minify",
    "build:webview": "cd webview && npx vite build",
    "watch:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "watch:webview": "cd webview && npx vite build --watch",
    "dev": "concurrently \"npm run watch:ext\" \"npm run watch:webview\"",
    "package": "vsce package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.95.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.1.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "ws": "^8.20.0"
  }
}
